# Set correct MIME types for sitemap and robots
AddType application/xml .xml
AddType text/plain .txt

# Ensure XML files are recognized correctly
<Files "sitemap.xml">
    ForceType application/xml
</Files>

# Ensure robots.txt is recognized correctly
<Files "robots.txt">
    ForceType text/plain
</Files>

# React Router catch-all for Hostinger SPA
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

